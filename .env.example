# =========================================================================
# Healty Docker Environment Variables Template
# =========================================================================
# Copy this file to '.env' and modify the values according to your needs.
# e.g., cp .env.example .env
# =========================================================================

# Database configuration
DB_ROOT_PASSWORD=super_secure_root_password
DB_NAME=healty
DB_USER=healty_user
DB_PASSWORD=healty_db_password
DB_HOST_PORT=3307

# Backend API Configuration
JWT_SECRET=7f5e3e2c1a0b9d8c7e6f5a4b3c2d1e0f
API_HOST_PORT=3011
RUN_SEEDS=true

# Frontend Configuration
FRONT_HOST_PORT=3010

# API base URL for client-side fetches.
# IMPORTANT: When deploying to production (IONOS), change 'localhost' to the domain 
# or public IP address of your server.
NUXT_PUBLIC_API_BASE_URL=http://localhost:3011/api/v1
